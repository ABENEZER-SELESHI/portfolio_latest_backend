generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
}

enum CertificateFileType {
  image
  pdf
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         UserRole  @default(ADMIN)
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model SiteSettings {
  id              String   @id @default(uuid()) @db.Uuid
  heroName        String   @default("Abenezer Seleshi") @map("hero_name")
  heroTitle       String   @default("Full-Stack Web Developer") @map("hero_title")
  heroIntro       String   @default("") @map("hero_intro") @db.Text
  aboutBio        String   @default("") @map("about_bio") @db.Text
  profileImageUrl String?  @map("profile_image_url")
  resumeUrl       String?  @map("resume_url")
  resumeFilename  String?  @map("resume_filename")
  linkedinUrl     String   @default("https://www.linkedin.com/in/abenezer-seleshi-66038a246/") @map("linkedin_url")
  githubUrl       String   @default("https://github.com/ABENEZER-SELESHI/") @map("github_url")
  contactEmail    String   @default("ebenezerseleshi@gmail.com") @map("contact_email")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model SkillCategory {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  skills Skill[]

  @@index([sortOrder])
  @@map("skill_categories")
}

model Skill {
  id         String    @id @default(uuid()) @db.Uuid
  categoryId String    @map("category_id") @db.Uuid
  name       String
  sortOrder  Int       @default(0) @map("sort_order")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  category SkillCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId, sortOrder])
  @@map("skills")
}

model TechStackItem {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  logoUrl     String?   @map("logo_url")
  proficiency Int?
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([sortOrder])
  @@map("tech_stack_items")
}

model Project {
  id           String    @id @default(uuid()) @db.Uuid
  title        String
  description  String    @db.Text
  screenshotUrl String?  @map("screenshot_url")
  liveUrl      String?   @map("live_url")
  githubUrl    String?   @map("github_url")
  category     String?
  isFeatured   Boolean   @default(false) @map("is_featured")
  completedAt  DateTime? @map("completed_at") @db.Date
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  technologies ProjectTechnology[]

  @@index([isFeatured, deletedAt])
  @@index([category])
  @@map("projects")
}

model ProjectTechnology {
  id         String @id @default(uuid()) @db.Uuid
  projectId  String @map("project_id") @db.Uuid
  technology String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([technology])
  @@map("project_technologies")
}

model Certificate {
  id          String               @id @default(uuid()) @db.Uuid
  name        String
  issuer      String
  issueDate   DateTime             @map("issue_date") @db.Date
  fileUrl     String?              @map("file_url")
  fileType    CertificateFileType? @map("file_type")
  externalUrl String?              @map("external_url")
  sortOrder   Int                  @default(0) @map("sort_order")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  deletedAt   DateTime?            @map("deleted_at")

  @@index([sortOrder])
  @@map("certificates")
}

model ContactMessage {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  email       String
  subject     String
  message     String    @db.Text
  isRead      Boolean   @default(false) @map("is_read")
  submittedAt DateTime  @default(now()) @map("submitted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([isRead, submittedAt])
  @@map("contact_messages")
}

model LoginAttempt {
  id           String    @id @default(uuid()) @db.Uuid
  ipAddress    String    @map("ip_address")
  attemptCount Int       @default(0) @map("attempt_count")
  windowStart  DateTime  @default(now()) @map("window_start")
  lockedUntil  DateTime? @map("locked_until")

  @@unique([ipAddress])
  @@map("login_attempts")
}
