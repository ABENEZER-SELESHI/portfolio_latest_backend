NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
# Comma-separated list of frontend URLs allowed to call the API (browser CORS)
# Production example: https://your-portfolio.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Local Docker Postgres (./scripts/start-postgres.sh)
# DATABASE_URL=postgresql://portfolio:portfolio_secret@localhost:5433/portfolio_db?schema=public
# Neon (production) — use pooled URL from dashboard; add &schema=public for Prisma
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&schema=public

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

ADMIN_EMAIL=admin@portfolio.local
ADMIN_PASSWORD=ChangeMe123!

BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
STORAGE_PUBLIC_URL=http://localhost:5000/uploads

# Brevo — https://app.brevo.com → SMTP & API
# API key (xkeysib-…) for brevo-api transport — NOT the SMTP key
BREVO_API_KEY=your-brevo-api-key
EMAIL_TRANSPORT=brevo-api
# Must be a sender verified in your Brevo account
SMTP_FROM=your-verified-sender@example.com
CONTACT_RECIPIENT=your-inbox@example.com
# SMTP relay (only if EMAIL_TRANSPORT=smtp)
SMTP_SERVER=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your-brevo-smtp-login@smtp-brevo.com
SMTP_PASSWORD=your-brevo-smtp-key
SMTP_ENCRYPTION=STARTTLS

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CONTACT_RATE_LIMIT_MAX=5
